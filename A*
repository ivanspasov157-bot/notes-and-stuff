import { graph } from "../data/graph.js";
import { nodePositions } from "../data/nodePositions.js";

// A MinHeap is used as a Priority Queue.
//
// Each item stored in the heap looks like:
//
// {
//   node: "A",
//   priority: 5
// }
//
// The item with the smallest priority
// is always removed first.
class MinHeap {
  constructor() {
    // Store the heap internally as an array.
    this.heap = [];
  }

  // Add a new item to the heap.
  push(item) {
    // Place the new item at the end.
    this.heap.push(item);

    // Move it upward until
    // the heap order is restored.
    this.bubbleUp();
  }

  // Remove and return the item
  // with the smallest priority.
  pop() {
    // Nothing can be removed
    // from an empty heap.
    if (this.heap.length === 0) {
      return null;
    }

    // When there is only one item,
    // remove and return it.
    if (this.heap.length === 1) {
      return this.heap.pop();
    }

    // The first item always has
    // the smallest priority.
    const smallestItem = this.heap[0];

    // Move the last item to the first position.
    this.heap[0] = this.heap.pop();

    // Move that item downward until
    // the heap is ordered correctly again.
    this.bubbleDown();

    return smallestItem;
  }

  // Move a newly added item upward
  // while its priority is smaller
  // than its parent's priority.
  bubbleUp() {
    let currentIndex = this.heap.length - 1;

    while (currentIndex > 0) {
      // Find the parent index.
      const parentIndex = Math.floor(
        (currentIndex - 1) / 2
      );

      // Stop when the parent already
      // has a smaller or equal priority.
      if (
        this.heap[parentIndex].priority <=
        this.heap[currentIndex].priority
      ) {
        break;
      }

      // Exchange the item with its parent.
      [
        this.heap[parentIndex],
        this.heap[currentIndex]
      ] = [
        this.heap[currentIndex],
        this.heap[parentIndex]
      ];

      currentIndex = parentIndex;
    }
  }

  // Move the first item downward
  // while one of its children
  // has a smaller priority.
  bubbleDown() {
    let currentIndex = 0;

    const heapLength = this.heap.length;

    while (true) {
      const leftChildIndex =
        2 * currentIndex + 1;

      const rightChildIndex =
        2 * currentIndex + 2;

      let smallestIndex = currentIndex;

      // Check the left child.
      if (
        leftChildIndex < heapLength &&
        this.heap[leftChildIndex].priority <
          this.heap[smallestIndex].priority
      ) {
        smallestIndex = leftChildIndex;
      }

      // Check the right child.
      if (
        rightChildIndex < heapLength &&
        this.heap[rightChildIndex].priority <
          this.heap[smallestIndex].priority
      ) {
        smallestIndex = rightChildIndex;
      }

      // Stop when the current item
      // is already the smallest.
      if (smallestIndex === currentIndex) {
        break;
      }

      // Exchange the current item
      // with its smaller child.
      [
        this.heap[currentIndex],
        this.heap[smallestIndex]
      ] = [
        this.heap[smallestIndex],
        this.heap[currentIndex]
      ];

      currentIndex = smallestIndex;
    }
  }

  // Return true when the heap is empty.
  isEmpty() {
    return this.heap.length === 0;
  }
}

// The heuristic estimates the remaining distance
// from one node to another.
//
// This version uses Euclidean distance,
// meaning straight-line distance.
function heuristic(nodeA, nodeB, positions) {
  // Get the coordinates of both nodes.
  const positionA = positions[nodeA];
  const positionB = positions[nodeB];

  // Calculate the horizontal difference.
  const differenceX =
    positionB.x - positionA.x;

  // Calculate the vertical difference.
  const differenceY =
    positionB.y - positionA.y;

  // Return the straight-line distance.
  return Math.sqrt(
    differenceX ** 2 +
    differenceY ** 2
  );
}

// A* finds the shortest weighted path
// from start to end.
//
// It uses:
//
// graph     → adjacency-list representation
// positions → coordinates for the heuristic
// start     → starting node
// end       → destination node
export function aStar(
  graph,
  positions,
  start,
  end
) {
  // Make sure both nodes exist
  // in the graph.
  if (!graph[start] || !graph[end]) {
    throw new Error(
      `Start node "${start}" or end node "${end}" does not exist.`
    );
  }

  // Make sure both nodes have coordinates.
  if (!positions[start] || !positions[end]) {
    throw new Error(
      "Every node used by A* must have a position."
    );
  }

  // gScore stores the smallest known
  // actual distance from start to each node.
  //
  // This is the same type of distance
  // stored by Dijkstra.
  const gScore = {};

  // fScore stores:
  //
  // actual known distance
  // +
  // estimated remaining distance
  //
  // fScore = gScore + heuristic
  const fScore = {};

  // previous stores which node led
  // to each node through the best known path.
  //
  // It is later used to rebuild the route.
  const previous = {};

  // Stores the order in which
  // nodes are processed.
  const visitedOrder = [];

  // Prevents the same node from being
  // permanently processed more than once.
  const visited = new Set();

  // Create the Priority Queue.
  const priorityQueue = new MinHeap();

  // Prepare values for every node.
  for (const node of Object.keys(graph)) {
    // At first, no route is known.
    gScore[node] = Infinity;

    // At first, no estimated total route
    // is known either.
    fScore[node] = Infinity;

    // No previous node is known yet.
    previous[node] = null;
  }

  // The actual distance from start
  // to itself is zero.
  gScore[start] = 0;

  // The starting node's estimated total cost
  // is only its heuristic estimate.
  fScore[start] = heuristic(
    start,
    end,
    positions
  );

  // Add the start node to the Priority Queue.
  priorityQueue.push({
    node: start,
    priority: fScore[start],
  });

  // Continue while nodes remain
  // waiting to be processed.
  while (!priorityQueue.isEmpty()) {
    // Remove the node with the smallest
    // estimated total cost.
    const currentItem =
      priorityQueue.pop();

    const current =
      currentItem.node;

    const currentPriority =
      currentItem.priority;

    // Skip the node if it was already
    // permanently processed.
    if (visited.has(current)) {
      continue;
    }

    // Skip outdated entries.
    //
    // A node can appear in the heap
    // more than once when a better
    // route is discovered later.
    if (
      currentPriority > fScore[current]
    ) {
      continue;
    }

    // The node is now being processed.
    visited.add(current);

    // Save it for visualization.
    visitedOrder.push(current);

    // Once A* removes the destination
    // from the heap, the shortest path
    // to it has been found.
    if (current === end) {
      break;
    }

    // Look through each connection
    // belonging to the current node.
    for (const connection of graph[current]) {
      // Extract the neighbouring node.
      const neighbor = connection.node;

      // Extract the edge weight.
      const weight = connection.weight;

      // Ignore nodes that were
      // already permanently processed.
      if (visited.has(neighbor)) {
        continue;
      }

      // Calculate the actual distance
      // to the neighbour through current.
      //
      // Example:
      //
      // gScore[current] = 4
      // weight = 2
      //
      // possibleGScore = 6
      const possibleGScore =
        gScore[current] + weight;

      // Check whether this is a better
      // actual route to the neighbour.
      if (
        possibleGScore < gScore[neighbor]
      ) {
        // Remember that this improved route
        // reaches neighbor from current.
        previous[neighbor] = current;

        // Update the neighbour's
        // actual known distance.
        gScore[neighbor] =
          possibleGScore;

        // Estimate the neighbour's
        // total route cost.
        //
        // fScore =
        // actual distance so far
        // +
        // estimated remaining distance
        fScore[neighbor] =
          gScore[neighbor] +
          heuristic(
            neighbor,
            end,
            positions
          );

        // Add the improved route
        // to the Priority Queue.
        priorityQueue.push({
          node: neighbor,
          priority: fScore[neighbor],
        });
      }
    }
  }

  // If the destination was never visited,
  // no path was found.
  if (!visited.has(end)) {
    return {
      visitedOrder,
      path: [],
      distance: Infinity,
    };
  }

  // Reconstruct the path backward
  // from the destination.
  const path = [];

  let currentNode = end;

  while (currentNode !== null) {
    path.push(currentNode);

    currentNode =
      previous[currentNode];
  }

  // The route is currently:
  //
  // end → ... → start
  //
  // Reverse it so it becomes:
  //
  // start → ... → end
  path.reverse();

  return {
    // Order in which A* processed nodes.
    visitedOrder,

    // Shortest weighted route.
    path,

    // Actual total path weight.
    //
    // We return gScore, not fScore,
    // because the heuristic is only an estimate.
    distance: gScore[end],
  };
}

