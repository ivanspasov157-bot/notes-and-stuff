import { graph } from "../data/graph.js";

// A MinHeap is used as a Priority Queue.
//
// Priority Queue means:
// items are removed according to their priority,
// rather than according to when they were added.
//
// In Dijkstra, the priority is the total distance.
//
// Every item stored in this heap looks like:
//
// {
//   node: "A",
//   distance: 0
// }
//
// The item with the smallest distance
// will always be removed first.
class MinHeap {
  constructor() {
    // The heap is stored internally as an array.
    this.heap = [];
  }

  // Add a new item to the heap.
  push(item) {
    // First, place the new item at the end.
    this.heap.push(item);

    // Then move it upward until the heap
    // is ordered correctly again.
    this.bubbleUp();
  }

  // Remove and return the item
  // with the smallest distance.
  pop() {
    // If the heap is empty,
    // there is nothing to remove.
    if (this.heap.length === 0) {
      return null;
    }

    // If there is only one item,
    // remove and return that item.
    if (this.heap.length === 1) {
      return this.heap.pop();
    }

    // The first item contains
    // the smallest distance.
    const smallestItem = this.heap[0];

    // Remove the final item from the array
    // and temporarily place it at the beginning.
    this.heap[0] = this.heap.pop();

    // Move that item downward until
    // the heap is ordered correctly again.
    this.bubbleDown();

    // Return the original smallest item.
    return smallestItem;
  }

  // Move the newly added item upward
  // until its parent has a smaller distance.
  bubbleUp() {
    // Start at the final item in the array.
    let currentIndex = this.heap.length - 1;

    // Continue while the current item
    // is not the first item.
    while (currentIndex > 0) {
      // Find the index of its parent.
      const parentIndex = Math.floor((currentIndex - 1) / 2);

      // If the parent already has a smaller
      // or equal distance, the heap is correct.
      if (
        this.heap[parentIndex].distance <=
        this.heap[currentIndex].distance
      ) {
        break;
      }

      // Otherwise, exchange the current item
      // with its parent.
      [
        this.heap[parentIndex],
        this.heap[currentIndex]
      ] = [
        this.heap[currentIndex],
        this.heap[parentIndex]
      ];

      // Continue checking from
      // the parent's former position.
      currentIndex = parentIndex;
    }
  }

  // Move the first item downward
  // until both children have larger distances.
  bubbleDown() {
    // Begin at the first item.
    let currentIndex = 0;

    const heapLength = this.heap.length;

    while (true) {
      // The heap is represented as an array,
      // but logically behaves like a binary tree.
      //
      // For an item at index i:
      //
      // left child  = 2 * i + 1
      // right child = 2 * i + 2
      const leftChildIndex = 2 * currentIndex + 1;
      const rightChildIndex = 2 * currentIndex + 2;

      // Assume the current item is the smallest.
      let smallestIndex = currentIndex;

      // Check whether the left child exists
      // and has a smaller distance.
      if (
        leftChildIndex < heapLength &&
        this.heap[leftChildIndex].distance <
          this.heap[smallestIndex].distance
      ) {
        smallestIndex = leftChildIndex;
      }

      // Check whether the right child exists
      // and has an even smaller distance.
      if (
        rightChildIndex < heapLength &&
        this.heap[rightChildIndex].distance <
          this.heap[smallestIndex].distance
      ) {
        smallestIndex = rightChildIndex;
      }

      // If the current item is still the smallest,
      // the heap is ordered correctly.
      if (smallestIndex === currentIndex) {
        break;
      }

      // Otherwise, exchange the current item
      // with the smaller child.
      [
        this.heap[currentIndex],
        this.heap[smallestIndex]
      ] = [
        this.heap[smallestIndex],
        this.heap[currentIndex]
      ];

      // Continue checking from
      // the child's former position.
      currentIndex = smallestIndex;
    }
  }

  // Returns true when the heap contains no items.
  isEmpty() {
    return this.heap.length === 0;
  }
}

// Dijkstra's algorithm finds the shortest weighted path.
//
// It receives:
//
// graph → the complete adjacency-list representation
// start → the node where the search begins
// end   → the destination node
export function dijkstra(graph, start, end) {
  // Make sure both selected nodes exist.
  if (!graph[start] || !graph[end]) {
    throw new Error(
      `Start node "${start}" or end node "${end}" does not exist.`
    );
  }

  // distances stores the smallest currently known
  // distance from start to every node.
  //
  // Example:
  //
  // {
  //   A: 0,
  //   B: Infinity,
  //   C: Infinity
  // }
  const distances = {};

  // previous remembers which node led to each node
  // through the shortest currently known route.
  //
  // It is later used to reconstruct the final path.
  //
  // Example:
  //
  // {
  //   A: null,
  //   B: "A",
  //   C: "B"
  // }
  const previous = {};

  // Stores the order in which nodes
  // are permanently processed.
  const visitedOrder = [];

  // Prevents us from permanently processing
  // the same node more than once.
  const visited = new Set();

  // Create the MinHeap Priority Queue.
  const priorityQueue = new MinHeap();

  // Prepare every node in the graph.
  for (const node of Object.keys(graph)) {
    // At first, we do not know how to reach any node,
    // so every distance begins as Infinity.
    distances[node] = Infinity;

    // At first, no node has a previous node.
    previous[node] = null;
  }

  // The distance from the starting node
  // to itself is always zero.
  distances[start] = 0;

  // Add the starting node to the Priority Queue.
  //
  // It receives priority zero because
  // its current distance is zero.
  priorityQueue.push({
    node: start,
    distance: 0,
  });

  // Continue while there are nodes
  // waiting to be processed.
  while (!priorityQueue.isEmpty()) {
    // Remove the item with
    // the smallest known distance.
    const currentItem = priorityQueue.pop();

    // Extract its values.
    const current = currentItem.node;
    const currentDistance = currentItem.distance;

    // The same node can appear in the heap more than once
    // when shorter routes are discovered.
    //
    // If this node was already permanently processed,
    // skip this copy.
    if (visited.has(current)) {
      continue;
    }

    // This check skips an outdated heap entry.
    //
    // Example:
    //
    // currentItem.distance = 8
    // distances[current] = 5
    //
    // This means a better route was discovered
    // after the distance of 8 was added to the heap.
    if (currentDistance > distances[current]) {
      continue;
    }

    // The smallest route to this node is now finalized.
    visited.add(current);

    // Save it for the visualization.
    visitedOrder.push(current);

    // If the destination has been reached,
    // the shortest path to it is finalized.
    if (current === end) {
      break;
    }

    // Look through every connection
    // belonging to the current node.
    //
    // Example:
    //
    // graph["A"] =
    // [
    //   { node: "B", weight: 2 },
    //   { node: "C", weight: 4 }
    // ]
    for (const connection of graph[current]) {
      // Extract the neighbouring node.
      const neighbor = connection.node;

      // Extract the weight of the edge
      // connecting current to neighbor.
      const weight = connection.weight;

      // Do not process a neighbour
      // whose shortest distance is already finalized.
      if (visited.has(neighbor)) {
        continue;
      }

      // Calculate the distance obtained
      // by travelling through the current node.
      //
      // Example:
      //
      // distance to current = 3
      // edge weight = 2
      //
      // possibleDistance = 5
      const possibleDistance =
        distances[current] + weight;

      // Compare the newly calculated distance
      // with the best distance currently known.
      if (possibleDistance < distances[neighbor]) {
        // A shorter route was found,
        // so update the neighbour's distance.
        distances[neighbor] = possibleDistance;

        // Remember that the improved route
        // reaches neighbor from current.
        previous[neighbor] = current;

        // Add the improved route to the Priority Queue.
        //
        // The MinHeap makes sure that the item
        // with the smallest distance is removed first.
        priorityQueue.push({
          node: neighbor,
          distance: possibleDistance,
        });
      }
    }
  }

  // If the end node was never visited,
  // there is no available route from start to end.
  if (!visited.has(end)) {
    return {
      visitedOrder,
      path: [],
      distance: Infinity,
    };
  }

  // Reconstruct the shortest path
  // by moving backward from end to start.
  const path = [];

  let currentNode = end;

  while (currentNode !== null) {
    path.push(currentNode);
    currentNode = previous[currentNode];
  }

  // The reconstructed path currently runs backward:
  //
  // end → ... → start
  //
  // Reverse it so it becomes:
  //
  // start → ... → end
  path.reverse();

  return {
    // Order in which Dijkstra finalized nodes.
    visitedOrder,

    // Shortest weighted path from start to end.
    path,

    // Total weight of that shortest path.
    distance: distances[end],
  };
}

